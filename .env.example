DATABASE_URL="postgresql://factoring:factoring@localhost:5432/factoring?schema=public"

JWT_SECRET="change-me-to-a-long-random-secret"
JWT_EXPIRES_IN="8h"

PORT=3000

# Lista de origens liberadas no CORS, separadas por virgula (ex.: "http://localhost:5173,https://app.minhaempresa.com").
# Se nao definida, usa um default permissivo de dev (Vite/CRA/Angular) -- ver src/main.ts.
# CORS_ORIGIN="http://localhost:5173"

# Storage de documentos (upload de cheque/duplicata/contrato) -- qualquer provedor S3-compativel.
# AWS S3: deixe STORAGE_S3_ENDPOINT vazio e STORAGE_S3_FORCE_PATH_STYLE="false".
# Cloudflare R2: STORAGE_S3_ENDPOINT="https://<account_id>.r2.cloudflarestorage.com", region "auto".
STORAGE_S3_BUCKET="factoring-documentos"
STORAGE_S3_REGION="auto"
STORAGE_S3_ENDPOINT=""
STORAGE_S3_FORCE_PATH_STYLE="false"
STORAGE_S3_ACCESS_KEY_ID="change-me"
STORAGE_S3_SECRET_ACCESS_KEY="change-me"
# URL publica base para montar o link do arquivo salvo (dominio do bucket, CDN ou dev domain do R2).
STORAGE_S3_PUBLIC_URL_BASE="https://pub-xxxxx.r2.dev"
